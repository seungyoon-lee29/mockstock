# web 환경변수. AUTH_* / DATABASE_URL 은 web 소유. KIS_* 는 여기 두지 말 것(B6/B14).

# 워커 SSE 직결 URL (B2). 미설정 시 /api/stream 로컬 폴백 사용.
NEXT_PUBLIC_STREAM_URL=http://localhost:8787/stream

# web → worker /snapshot 호출 (T04 시장가 체결가 조회). 2.5초 타임아웃 + 스냅샷 30초
# 신선도 게이트 — 미응답·타임아웃·스테일은 전부 fail-closed(§6.1). 미설정 시 주문 접수 거부.
# WORKER_SECRET 은 worker와 동일 값(x-worker-secret 헤더로 전송, B1).
WORKER_SNAPSHOT_URL=http://localhost:8787/snapshot
WORKER_SECRET=

# web → worker /candles/backfill 타임아웃 ms (멀티 타임프레임 v2). 외부 API(KIS/Alpaca) 경유라
# 스냅샷 2.5초와 별개로 여유 있게. 미설정 시 기본 15000. 초과·실패는 조용히 DB-only 강등(fail-open).
BACKFILL_TIMEOUT_MS=15000

# Neon Postgres (drizzle neon-serverless). T02부터.
DATABASE_URL=

# Better Auth (T03). 이메일+비밀번호 + google OAuth + anonymous(게스트).
# SECRET: 세션 서명 키(32자+ 고엔트로피). 생성 → `openssl rand -base64 32`. 프로덕션 미설정 시 시작 실패.
BETTER_AUTH_SECRET=
# 배포 시 실제 오리진으로(콜백·Origin 검증 베이스). 프로덕션 미설정 시 요청에서 파생(경고).
BETTER_AUTH_URL=http://localhost:3000
# Google OAuth(선택 — 이메일/비번만 쓰면 불필요): https://console.cloud.google.com/apis/credentials
#   승인된 리디렉션 URI = {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 이메일+비밀번호는 별도 키 불필요(스키마·해시 내장). 단 프로덕션에서 이메일을 신뢰 앵커로 쓰려면
# requireEmailVerification:true(auth.ts) + 메일 발송 구성 필요. rate-limit는 인스턴스 로컬 메모리라
# Vercel 멀티 인스턴스면 공유 스토리지(Redis) 권장(codex 리뷰).

# AI 투자 성향 요약 (§D8). 선택 — 키가 없으면 규칙 기반 간이 분석으로 폴백(에러 아님).
ANTHROPIC_API_KEY=
# 선택. 미설정 시 기본 claude-haiku-4-5 (shared PROFILE_DEFAULT_MODEL).
ANTHROPIC_MODEL=

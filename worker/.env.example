# 워커 환경변수. KIS_* / FINNHUB_* 는 워커에만 존재(web 금지, B6/B14).

PORT=8787

# 시장별 피드 소스 (B4). 실 연동 전까진 mock.
#  FEED_KR = kis | mock
#  FEED_US = finnhub | mock
FEED_KR=mock
FEED_US=mock

# web → worker /snapshot 호출 인증 (B1). 미설정 시 검증 생략(로컬).
WORKER_SECRET=

# 브라우저 SSE 허용 오리진 (B2). 로컬은 * , 프로드는 web 오리진 고정.
CORS_ORIGIN=*

# Neon (worker는 장중 한정 접근으로 autosuspend 보존, B13). T05까진 불필요.
DATABASE_URL=

# 실 연동 키 (T05). 발급 전까진 비워두고 FEED_*=mock 유지.
FINNHUB_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=

# ── 시즌·크론 (T06) ─────────────────────────────────────────────────────────
# 크론 완료·실패 통지 (§7.6). 미설정 시 콘솔 로그로 폴백.
DISCORD_WEBHOOK_URL=

# 시즌 경계 파라미터화 (§4.1 크론 검증). 미설정 시 주간(월 00:00→금 15:30 KST) / 시드 1,000만.
#  SEASON_DURATION_MS: 지정 시 고정 길이 롤링 시즌(예: 600000 = 10분짜리 풀사이클 테스트).
SEASON_DURATION_MS=
SEASON_SEED_KRW=

# ── 봇 (T07 · §4.3 공개 벤치마크) ───────────────────────────────────────────
# "3분 관전 중 리더보드 순위 변동 ≥1회" 튜닝 레버(§10 데모 전제). DATABASE_URL 없으면 자동 비활성.
#  BOT_COUNT: 봇 수(기본 3 = 랜덤봇·모멘텀봇·인덱스봇 1개씩. >3 이면 번호 붙여 순환).
#  BOT_INTERVAL_SEC: 매매 주기 초(기본 45).
#  BOT_ORDER_PCT: 1회 주문 시드 대비 비율(기본 0.1 = 10%).
BOT_COUNT=
BOT_INTERVAL_SEC=
BOT_ORDER_PCT=

# ── 과거 캔들 백필·일봉 동기화 (멀티 타임프레임 v2, 배치 B) ─────────────────
# Alpaca Market Data(US 과거 분·일봉, Basic 플랜 feed=iex). 없으면 US 백필·일봉 비활성(빈 배열).
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# KIS REST 도메인 — 기본 실전 https://openapi.koreainvestment.com:9443 (WS의 VTS와 별개 경로).
KIS_REST_BASE=
# KIS REST 초당 호출 상한(기본 5) — 신규 고객 한도 공지 보수 대응.
KIS_REST_RPS=
# /candles/backfill 요청당 KIS 콜 예산(기본 10 ≈ 1200분봉). 소진 시 부분 응답(오래된 쪽 절단).
KIS_BACKFILL_CALL_BUDGET=
# daily_candles 부팅 백필 일수(기본 730).
DAILY_BACKFILL_DAYS=

# ── KR 리플레이 과거 일봉 수집 (1회성, ADR 0003) ────────────────────────────
# 공공데이터포털 금융위원회_주식시세정보(데이터셋 15094808) 인증키(서비스키).
# KR 리플레이 과거 일봉 수집용(1회성). 발급: https://www.data.go.kr/data/15094808/openapi.do
DATA_GO_KR_SERVICE_KEY=
